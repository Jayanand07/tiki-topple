# Tiki Topple — Environment Variables
# Copy this to .env.local and fill in your values

# Frontend URL (Vercel deployment)
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# boardgame.io server URL (Railway deployment)
NEXT_PUBLIC_SERVER_URL=https://your-app.railway.app

# Server-side: allowed frontend origin for CORS
FRONTEND_URL=https://your-app.vercel.app

# Server port (Railway assigns this automatically)
PORT=3001
